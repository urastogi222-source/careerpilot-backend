import os, re, json
from fastapi import APIRouter, UploadFile, File, HTTPException
from sqlalchemy.orm import Session

router = APIRouter()

ROLE_KEYWORDS = {
    "software_engineer": ["python","java","javascript","react","node","sql","api","git","agile","scrum","docker","kubernetes","ci/cd","rest","microservices","testing","aws","algorithms"],
    "data_analyst": ["python","sql","excel","tableau","power bi","pandas","numpy","data visualization","machine learning","statistics","etl","reporting","analytics","r"],
    "product_manager": ["product roadmap","agile","scrum","stakeholder","user stories","kpi","metrics","market research","jira","wireframe","a/b testing","prioritization"],
    "mba_management": ["leadership","strategy","p&l","revenue","stakeholder management","business development","team management","budget","forecasting","operations","consulting"],
    "general": ["communication","leadership","teamwork","problem solving","analytical","project management","microsoft office","excel","presentation","time management","critical thinking"],
}

def extract_text(filename: str, content: bytes) -> str:
    if filename.lower().endswith(".pdf"):
        import io
        try:
            import pdfplumber
            with pdfplumber.open(io.BytesIO(content)) as pdf:
                return "\n".join(page.extract_text() or "" for page in pdf.pages)
        except:
            raise HTTPException(status_code=400, detail="Could not read PDF. Make sure it's a text-based PDF, not a scanned image.")
    elif filename.lower().endswith(".docx"):
        import tempfile, docx2txt
        with tempfile.NamedTemporaryFile(delete=False, suffix=".docx") as tmp:
            tmp.write(content); tmp_path = tmp.name
        text = docx2txt.process(tmp_path)
        os.unlink(tmp_path)
        return text
    elif filename.lower().endswith(".txt"):
        return content.decode("utf-8", errors="ignore")
    else:
        raise HTTPException(status_code=400, detail="Unsupported file. Please upload PDF, DOCX, or TXT.")

def rule_based_ats(text: str, role: str) -> dict:
    text_lower = text.lower()
    keywords = ROLE_KEYWORDS.get(role, ROLE_KEYWORDS["general"])
    matched  = [k for k in keywords if k in text_lower]
    missing  = [k for k in keywords if k not in text_lower]
    kw_score = round((len(matched) / len(keywords)) * 100)

    checks = {
        "Contact Info (Email)":   bool(re.search(r'[\w.+-]+@[\w-]+\.\w+', text)),
        "Phone Number":           bool(re.search(r'[\+\(]?[0-9][0-9\s\-\(\)]{8,}[0-9]', text)),
        "LinkedIn URL":           "linkedin" in text_lower,
        "Professional Summary":   any(w in text_lower for w in ["summary","objective","profile","about"]),
        "Work Experience":        any(w in text_lower for w in ["experience","work history","employment"]),
        "Education Section":      any(w in text_lower for w in ["education","degree","university","college","b.tech","mba"]),
        "Skills Section":         "skills" in text_lower,
        "Bullet Points Used":     text.count("•") + text.count("-") > 5,
        "Good Length (300-900w)": 300 < len(text.split()) < 900,
    }
    struct_score = round((sum(checks.values()) / len(checks)) * 100)
    total_score  = round(kw_score * 0.55 + struct_score * 0.45)

    return {
        "total_score": total_score, "keyword_score": kw_score,
        "structure_score": struct_score, "word_count": len(text.split()),
        "matched_keywords": matched, "missing_keywords": missing[:8],
        "structure_checks": checks,
    }

def ai_feedback(text: str, role: str, scores: dict) -> dict:
    anthropic_key = os.getenv("ANTHROPIC_API_KEY", "")
    if not anthropic_key or anthropic_key in ("skip-for-now", ""):
        # Return rule-based feedback if no API key
        score = scores["total_score"]
        return {
            "overall_verdict": f"Your resume scored {score}/100. {'Good foundation but needs improvement.' if score < 70 else 'Strong resume!'}",
            "grade": "A" if score>=85 else "B" if score>=70 else "C" if score>=55 else "D",
            "strengths": [f"Matched {len(scores['matched_keywords'])} keywords" , "Resume submitted successfully", "Structure detected"],
            "critical_fixes": scores["missing_keywords"][:3] or ["Add more industry keywords"],
            "quick_wins": ["Add LinkedIn URL", "Quantify achievements with numbers", "Add a professional summary"],
            "tone_feedback": "Review your resume for professional tone and action verbs.",
            "impact_score": score,
            "recruiter_tip": "Tailor your resume for each job description you apply to."
        }
    try:
        from anthropic import Anthropic
        client = Anthropic(api_key=anthropic_key)
        prompt = f"""Analyze this resume for a {role.replace('_',' ')} role.
ATS Score: {scores['total_score']}/100. Missing keywords: {', '.join(scores['missing_keywords'])}.
Resume: {text[:2000]}
Respond ONLY with valid JSON (no markdown):
{{"overall_verdict":"...","grade":"A/B/C/D","strengths":["...","...","..."],"critical_fixes":["...","...","..."],"quick_wins":["...","...","..."],"tone_feedback":"...","impact_score":75,"recruiter_tip":"..."}}"""
        response = client.messages.create(model="claude-sonnet-4-20250514", max_tokens=800,
                                          messages=[{"role":"user","content":prompt}])
        raw = response.content[0].text.strip().replace("```json","").replace("```","")
        return json.loads(raw)
    except Exception as e:
        print(f"AI feedback error: {e}")
        return ai_feedback(text, role, scores)  # fallback to rule-based

@router.post("/analyze")
async def analyze_resume(file: UploadFile = File(...), role: str = "general"):
    content = await file.read()
    if len(content) > 5 * 1024 * 1024:
        raise HTTPException(status_code=400, detail="File too large. Max 5MB.")
    text = extract_text(file.filename, content)
    if len(text.strip()) < 50:
        raise HTTPException(status_code=400, detail="Could not extract text. Try a text-based PDF.")
    scores   = rule_based_ats(text, role)
    feedback = ai_feedback(text, role, scores)
    return {"filename": file.filename, "role": role, "scores": scores, "feedback": feedback, "status": "success"}

@router.get("/roles")
def get_roles():
    return {"roles": [
        {"id": "software_engineer", "label": "Software Engineer / Developer"},
        {"id": "data_analyst",      "label": "Data Analyst / Data Scientist"},
        {"id": "product_manager",   "label": "Product Manager"},
        {"id": "mba_management",    "label": "MBA / Management"},
        {"id": "general",           "label": "General / Other"},
    ]}
